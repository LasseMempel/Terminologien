{"componentChunkName":"component---src-components-concept-jsx","path":"/http://data.archaeology.link/terminology/archeologicalconservation/A9D149.html","result":{"pageContext":{"node":{"id":"http://data.archaeology.link/terminology/archeologicalconservation/A9D149","type":"Concept","prefLabel":{"en":null,"de":"Vacuumtränkung","fr":null},"altLabel":{"en":null,"de":["Niederdrucktränkung"],"fr":null},"hiddenLabel":null,"definition":{"en":null,"de":"Spezielle Art der Badtränkung, bei der die Zugabe des Festigungsmittel (ein gelöstes Polymer) unter Vakuum, z.B. in einem Exsikkator, erfolgt. Durch das erzeugte Vakuum entsteht ein Sog, der die Polymerlösung tiefer in den Porenraum des Objektmaterials zieht. Auf diese Weise ist eine besonders gute Penetration des Objektes mit dem Festigungsmittel möglich. Allerdings ist die Methode nicht für sehr fragile Objekte geeignet, da der erzeugte Druck durch das Vakuum die instabile Struktur des Materials weiter beschädigen könnte.","fr":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["A9D149"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"http://data.archaeology.link/terminology/archeologicalconservation/C17A3G","prefLabel":{"en":null,"de":"Badtränkung","fr":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation","title":null}],"inSchemeAll":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://lassemempel.github.io/Terminologien/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}