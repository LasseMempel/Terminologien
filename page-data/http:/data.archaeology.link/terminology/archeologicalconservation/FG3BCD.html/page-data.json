{"componentChunkName":"component---src-components-concept-jsx","path":"/http://data.archaeology.link/terminology/archeologicalconservation/FG3BCD.html","result":{"pageContext":{"node":{"id":"http://data.archaeology.link/terminology/archeologicalconservation/FG3BCD","type":"Concept","prefLabel":{"en":null,"de":"Eichenholz","fr":null},"altLabel":{"en":["oak"],"de":["Quercus species"],"fr":null},"hiddenLabel":null,"definition":{"en":null,"de":"Holz aus Eichenbäumen. Das Holz der verschiedenen Eichenbäumen ist im allgemeinen als starkes und strapazierfähiges Holz zu beschreiben, welches eine üblicherweise hellbraune bis gelblich-braun/rötliche Färbung aufweist. Die Maserung verläuft häufig in markanten, wellenförmigen/gespiegelten Formen. Die mechanische Bearbeitbarkeit hängt im Detail von der jeweiligen Eichenart ab, ist insgesamt jedoch als gut zu beschreiben.","fr":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["FG3BCD"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"http://data.archaeology.link/terminology/archeologicalconservation/D39191","prefLabel":{"en":null,"de":"ringporiges Laubholz","fr":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":[{"id":"http%3A//vocab.getty.edu/page/aat/300012264"},{"id":"https%3A//cameo.mfa.org/wiki/Oak"}],"exactMatch":null,"inScheme":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation","title":null}],"inSchemeAll":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://lassemempel.github.io/Terminologien/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}