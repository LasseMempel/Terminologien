{"componentChunkName":"component---src-components-concept-jsx","path":"/http://data.archaeology.link/terminology/archeologicalconservation/FA5484.html","result":{"pageContext":{"node":{"id":"http://data.archaeology.link/terminology/archeologicalconservation/FA5484","type":"Concept","prefLabel":{"en":null,"de":"Amphibol","fr":null},"altLabel":null,"hiddenLabel":null,"definition":{"en":null,"de":"Gruppe von Eisen-Magnesium-Silikatmineralen mit mittlerer Härte. Die Färbung ist meit dunkel, von grün bis schwarzer Farbe. Die Färbung hängt dabei vor allem vom Eisen-Gehalt der Mineralie ab. Die Spaltflächen der Amphibole zeigen sich oft mit einem Glas- oder Perlmuttglanz, während die nadeligen, faserartigen Formen von einem seidigen Glanz sind. Amphibole kommen in vielen magmatischen und metamorphosen Gesteinen vor, wie z. B in Graniten, Dioriten und vor allem in den Amphiobioliten.","fr":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["FA5484"],"example":null,"narrower":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation/A43C59","prefLabel":{"en":null,"de":"Hornblende","fr":null}}],"narrowerTransitive":[],"broader":{"id":"http://data.archaeology.link/terminology/archeologicalconservation/BGC9F3","prefLabel":{"en":null,"de":"Mineral","fr":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation","title":null}],"inSchemeAll":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://lassemempel.github.io/Terminologien/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}