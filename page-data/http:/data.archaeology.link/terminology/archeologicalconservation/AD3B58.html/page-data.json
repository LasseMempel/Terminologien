{"componentChunkName":"component---src-components-concept-jsx","path":"/http://data.archaeology.link/terminology/archeologicalconservation/AD3B58.html","result":{"pageContext":{"node":{"id":"http://data.archaeology.link/terminology/archeologicalconservation/AD3B58","type":"Concept","prefLabel":{"de":"Korund","en":null,"fr":null},"altLabel":null,"hiddenLabel":null,"definition":{"de":"sehr hartes Mineral aus Aluminiumoxid, welches je nach enthaltenen Spurenelementen in ganz unterschiedlichen Farben auftreten kann. Die bekanntesten Varietäten sind Rubin und Saphir. Korund ist nach Diamant das zweithärteste, natürlich vorkommende Material mit einer Mohshärte von 9. Korund weist eine hohe Dichte, einen glasartigen Glanz sowie einen muscheligen Bruch auf.","en":null,"fr":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["AD3B58"],"example":null,"narrower":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation/BC5A3C","prefLabel":{"de":"Saphir","en":null,"fr":null}},{"id":"http://data.archaeology.link/terminology/archeologicalconservation/D75514","prefLabel":{"de":"Rubin","en":null,"fr":null}}],"narrowerTransitive":[],"broader":{"id":"http://data.archaeology.link/terminology/archeologicalconservation/BGC9F3","prefLabel":{"de":"Mineral","en":null,"fr":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":[{"id":"https%3A//www.mindat.org/min-1136.html"}],"exactMatch":null,"inScheme":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation","title":null}],"inSchemeAll":[{"id":"http://data.archaeology.link/terminology/archeologicalconservation"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://lassemempel.github.io/Terminologien/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}