{"componentChunkName":"component---src-components-concept-jsx","path":"/https://github.com/LasseMempel/Terminologien/Konservierungsthesaurus/D74CG7.html","result":{"pageContext":{"node":{"id":"https://github.com/LasseMempel/Terminologien/Konservierungsthesaurus/D74CG7","type":"Concept","prefLabel":{"de":"aufgezogen","en":null,"fr":null},"altLabel":{"de":["Aufziehen"],"en":null,"fr":null},"hiddenLabel":null,"definition":{"de":"Treibtechnik, bei der ein Blech durch gezielte und genau dosierte Hammerschläge so gestaucht wird, dass sich sein Rand zwangsweise nach oben und innen wölbt. Auf diese Weise wird durch sich ständig wiederholendes Stauchen und Strecken ein Hohlkörper gebildet, dessen Ausgestaltung \"frei Hand\" geformt wird. Die Bearbeitung erfolgt dabei auf weicher (Holz) oder harter (Stahl) Unterlage, ohne Gegenform, die die endgültige Form des Hohlkörpers vorgibt.","en":null,"fr":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["D74CG7"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://github.com/LasseMempel/Terminologien/Konservierungsthesaurus/D18BBG","prefLabel":{"de":"getrieben","en":null,"fr":null}},"broaderTransitive":null,"related":[],"relatedMatch":null,"broadMatch":null,"narrowMatch":null,"closeMatch":null,"exactMatch":null,"inScheme":[{"id":"https://github.com/LasseMempel/Terminologien/Konservierungsthesaurus","title":null}],"inSchemeAll":[{"id":"https://github.com/LasseMempel/Terminologien/Konservierungsthesaurus"}],"topConceptOf":[],"deprecated":null,"isReplacedBy":null},"collections":[],"customDomain":"https://lassemempel.github.io/Terminologien/"}},"staticQueryHashes":["3649515864","4240049689","63159454"],"slicesMap":{}}